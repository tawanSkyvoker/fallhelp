# FallHelp Mobile Environment Variables
# คัดลอกไฟล์นี้เป็น .env ก่อนรันโปรเจกต์

# ==================== Backend API ====================
# Mobile app เรียก backend/socket ผ่าน URL นี้
# Public/Cloudflare: https://api.your-domain.com
# Local LAN: http://192.168.x.x:3000
EXPO_PUBLIC_API_URL=https://api.your-domain.com
EXPO_PUBLIC_SOCKET_URL=https://api.your-domain.com

# ==================== Tunnel Mode ====================
# true = บังคับใช้ EXPO_PUBLIC_* URL, false = ให้ dev mode auto-detect local IP ได้
EXPO_PUBLIC_FORCE_PUBLIC=false

# ==================== Android Google Services ====================
# Optional: Base64 JSON content สำหรับ Android native Google services
GOOGLE_SERVICES_JSON_BASE64=
