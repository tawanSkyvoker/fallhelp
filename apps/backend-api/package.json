{
  "name": "backend-api",
  "version": "1.0.0",
  "description": "FallHelp Backend - Prisma 7",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "npm run debug",
    "dev:server": "tsx watch src/server.ts",
    "debug": "cross-env DEBUG=fallhelp:* tsx watch src/server.ts",
    "postinstall": "node ../../scripts/dev/postinstall-stamp.mjs backend",
    "build": "tsc",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run prisma:generate && prisma migrate dev && npm run prisma:seed",
    "db:reset": "npm run prisma:generate && prisma migrate reset --force && npm run prisma:seed",
    "db:verify": "npm run prisma:generate && tsx scripts/verify-db.ts",
    "db:test:setup": "tsx scripts/setup-test-db.ts",
    "db:test:reset": "tsx scripts/setup-test-db.ts --reset",
    "test": "jest --config jest.config.cjs",
    "test:ci": "jest --config jest.config.cjs --runInBand --watchman=false",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "test:handles": "cross-env JEST_DETECT_OPEN_HANDLES=true jest --config jest.config.cjs --runInBand --watchman=false",
    "test:integration:raw": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.integration.config.cjs --runInBand",
    "test:integration": "npm run db:test:setup && npm run test:integration:raw",
    "test:all": "npm test && npm run test:integration",
    "lint": "eslint src scripts --ext .ts",
    "lint:fix": "eslint src scripts --ext .ts --fix",
    "format": "prettier --write \"{src,scripts}/**/*.{ts,json,md}\"",
    "audit:dead-code": "knip",
    "sim:events": "tsx scripts/sim-events.ts",
    "sim:fall": "tsx scripts/sim-fall.ts",
    "sim:push": "tsx scripts/sim-push.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "debug": "^4.4.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "mqtt": "^5.15.0",
    "pg": "^8.20.0",
    "resend": "^6.9.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "30.2.0",
    "knip": "^6.0.4",
    "prettier": "^3.8.1",
    "prisma": "7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.56.1"
  }
}
