# ==================== DATABASE ====================
# PostgreSQL
#
# ใช้ตัวแปรให้ถูกตาม context การรัน:
#   npm run dev:all  → backend รันบน host โดยตรง → ใช้ DATABASE_URL (localhost)
#   docker compose   → backend รันใน container  → ใช้ DATABASE_URL_DOCKER (host.docker.internal)
#
# สำหรับ npm run dev:all (backend บน host)
DATABASE_URL="postgresql://username:password@localhost:5432/fallhelp_db?schema=public"

# สำหรับ docker compose up (backend ใน container)
DATABASE_URL_DOCKER="postgresql://username:password@host.docker.internal:5432/fallhelp_db?schema=public"

# ==================== JWT AUTHENTICATION ====================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ==================== SERVER ====================
# Backend listen local; Cloudflare Tunnel แค่ forward เข้ามาที่ port นี้
# Public API URL ให้ตั้งใน mobile/admin client config
PORT=3000
NODE_ENV="development"
LOG_LEVEL="debug"
API_BASE_URL="http://localhost:3000"

# ==================== MQTT BROKER (IoT Devices) ====================
# ติดตั้ง Mosquitto service: https://mosquitto.org/download/
#   Windows: choco install mosquitto   → รัน Services → mosquitto
#   Linux:   sudo apt install mosquitto && sudo systemctl enable --now mosquitto
#
# MQTT_BROKER_URL     → ใช้เมื่อ backend รันบน host (npm run dev:all)
# MQTT_BROKER_URL_DOCKER → ใช้เมื่อ backend รันใน Docker container
#   Docker container เข้าถึง host Mosquitto ผ่าน host.docker.internal
#   ถ้าไม่ตั้ง MQTT_BROKER_URL_DOCKER จะ default เป็น mqtt://host.docker.internal:1883
#
# Local Mosquitto:
# MQTT_BROKER_URL="mqtt://localhost:1883"
# MQTT_BROKER_URL_DOCKER="mqtt://host.docker.internal:1883"  ← optional, มี default แล้ว
#
# HiveMQ Cloud (TLS) — ใช้ค่าเดียวกันทั้งสอง context:
# MQTT_BROKER_URL="mqtts://xxxxxxxx.s1.eu.hivemq.cloud:8883"
# MQTT_BROKER_URL_DOCKER="mqtts://xxxxxxxx.s1.eu.hivemq.cloud:8883"
# MQTT_USERNAME="your-hivemq-username"
# MQTT_PASSWORD="your-hivemq-password"
#
# ESP32 ไม่ใช้ MQTT_BROKER_URL นี้; ให้ตั้ง LAN IP ใน firmware secrets แทน
MQTT_BROKER_URL="mqtt://localhost:1883"
MQTT_BROKER_URL_DOCKER="mqtt://host.docker.internal:1883"
MQTT_USERNAME=""
MQTT_PASSWORD=""
MQTT_DISABLED="false"

# ==================== CORS ====================
# Frontend/Mobile App URL for CORS
FRONTEND_URL="http://localhost:8081"
ADMIN_URL="http://localhost:5173"

# Optional: build-time API URL for admin Docker image
# Used by: root docker-compose.yml
ADMIN_VITE_API_URL="http://localhost:3000/api"

# ==================== EMAIL (Resend) ====================
# Get your API key from: https://resend.com/api-keys
# Free tier: 3,000 emails/month
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="FallHelp <noreply@your-domain.com>"

# Disable email sending for testing (emails will be logged to console only)
# Set to 'true' to disable, remove or set to 'false' to enable
DISABLE_EMAIL=false

# ==================== ADMIN SEED ====================
# Used by: npx prisma db seed
# These are used ONLY for initial Admin account creation
ADMIN_EMAIL="admin@fallhelp.com"
ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
ADMIN_FIRST_NAME="System"
ADMIN_LAST_NAME="Admin"

# ==================== ENCRYPTION ====================
# Must be exactly 32 characters
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef"

# ==================== CLOUDFLARE TUNNEL ====================
# Named Tunnel จาก Cloudflare Dashboard; เว้นว่างได้ถ้าไม่รัน tunnel service
# Run from repo root: docker compose --env-file apps/backend-api/.env --profile tunnel up
TUNNEL_TOKEN=""
# Public hostname ที่ mobile/admin เรียกผ่าน Cloudflare
TUNNEL_PUBLIC_HOSTNAME="api.your-domain.com"
# Origin service ที่ cloudflared container forward เข้า Docker network
TUNNEL_ORIGIN_URL="http://backend:3000"

# ==================== NODE-RED / SENSOR LAB ====================
# MQTT config for Node-RED Fall Detection Sensor Lab flow (รัน Node-RED ผ่าน Docker)
# host.docker.internal → ชี้ไป Mosquitto service บน host machine (ทั้ง Windows/Mac/Linux)
# HiveMQ Cloud: MQTT_BROKER_HOST=<cluster>.hivemq.cloud, MQTT_BROKER_PORT=8883, MQTT_USE_TLS=true
# MQTT_USERNAME and MQTT_PASSWORD are shared with backend above
MQTT_BROKER_HOST=host.docker.internal
MQTT_BROKER_PORT=1883
MQTT_USE_TLS=false
NODE_RED_PORT=1880
