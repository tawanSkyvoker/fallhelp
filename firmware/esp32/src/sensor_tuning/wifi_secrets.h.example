/**
 * @file wifi_secrets.h.example
 * @brief ตัวอย่างไฟล์ตั้งค่า WiFi + Local MQTT สำหรับ sensor_tuning
 *
 * วิธีใช้:
 *   1. คัดลอกไฟล์นี้ → ตั้งชื่อว่า  wifi_secrets.h
 *   2. กรอกค่า WiFi ของวง LAN ที่ ESP32 และเครื่องคอมพิวเตอร์ใช้อยู่ร่วมกัน
 *   3. กรอก LAN IP เครื่องที่รัน Mosquitto service
 *   4. ไฟล์นี้ตั้งใจให้ใช้ local-only จึงไม่มี Cloud MQTT profile
 *   5. ไฟล์  wifi_secrets.h  ถูกเพิ่มใน .gitignore แล้ว — ปลอดภัย ไม่ถูก commit
 */

#ifndef FALLHELP_WIFI_SECRETS_H
#define FALLHELP_WIFI_SECRETS_H

// WiFi สำหรับรอบจูนในแล็บ — sensor_tuning ไม่ใช้ BLE provisioning
#define WIFI_SSID "YOUR_WIFI_SSID"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

// Mosquitto service รันบน host machine — ใส่ LAN IP จริงของเครื่อง; ESP32 เชื่อมตรงผ่าน IP เท่านั้น
#define LOCAL_MQTT_HOST "192.168.1.xxx"
#define LOCAL_MQTT_PORT 1883

#endif
