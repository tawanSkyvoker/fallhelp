/**
 * @file mqtt_secrets.h.example
 * @brief ตัวอย่างไฟล์ตั้งค่า MQTT broker — คัดลอกไฟล์นี้เป็น mqtt_secrets.h แล้วแก้ค่า
 *
 * วิธีใช้:
 *   1. คัดลอกไฟล์นี้ → ตั้งชื่อว่า  mqtt_secrets.h
 *   2. เลือก Cloud HiveMQ หรือ Local Mosquitto แล้วกรอกค่า host/port/transport ให้ตรง profile
 *   3. เปิดใช้ profile เดียว และใส่ // หน้าชุดที่ไม่ใช้
 *   4. ไฟล์  mqtt_secrets.h  ถูกเพิ่มใน .gitignore แล้ว — ปลอดภัย ไม่ถูก commit
 */

#ifndef MQTT_SECRETS_H
#define MQTT_SECRETS_H

// ---------------------------------------------------------------------------
// Profile A: Cloud HiveMQ (TLS)
// ---------------------------------------------------------------------------
// ดูค่าได้ที่ console.hivemq.cloud -> Cluster -> Overview + Access Management
// เปิดใช้แค่ profile เดียว: ชุดที่ไม่ใช้ให้ใส่ // ไว้หน้า #define
#define HIVEMQ_HOST     "xxxxxxxx.s1.eu.hivemq.cloud"
#define HIVEMQ_PORT     8883
#define FALLHELP_MQTT_USE_TLS 1
#define FALLHELP_MQTT_BROKER_LABEL "HiveMQ Cloud"

// ---------------------------------------------------------------------------
// Profile B: Local Mosquitto (plain TCP)
// ---------------------------------------------------------------------------
// ใส่ LAN IP เครื่องที่รัน Mosquitto service; ESP32 เชื่อมตรงผ่าน IP จริงเท่านั้น
// ตรวจสอบ service และ firewall ก่อนด้วย: npm run mqtt:check
// #define HIVEMQ_HOST     "192.168.1.xxx"
// #define HIVEMQ_PORT     1883
// #define FALLHELP_MQTT_USE_TLS 0
// #define FALLHELP_MQTT_BROKER_LABEL "Local Mosquitto" // label สำหรับ log ของเครื่อง local

// Local Mosquitto แบบ no-auth ให้เว้นเป็น "" ได้ แต่ Cloud HiveMQ ต้องกรอก username/password
#define HIVEMQ_USERNAME "your-username"
#define HIVEMQ_PASSWORD "your-password"

// 0 = ข้าม cert verify ใน TLS mode (dev/prototype)
// 1 = strict TLS สำหรับ Cloud broker — ต้องแนบ HIVEMQ_ROOT_CA ด้วย
// ไม่มีผลกับ Local Mosquitto profile เพราะ local ใช้ plain TCP
#define HIVEMQ_TLS_VERIFY 0

static const char HIVEMQ_ROOT_CA[] PROGMEM = R"EOF(
-----BEGIN CERTIFICATE-----
<วาง ISRG Root X1 certificate ที่นี่>
-----END CERTIFICATE-----
)EOF";

#endif // MQTT_SECRETS_H
